PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/ghost_employee_detection
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1h
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Optional internal service token for trusted device/bridge-to-API calls.
INTERNAL_SERVICE_API_KEY=replace-with-a-long-random-service-token

# One-time initial admin bootstrap. Remove or rotate after use.
AUTH_BOOTSTRAP_TOKEN=replace-with-a-one-time-bootstrap-token
INITIAL_ADMIN_USERNAME=admin@example.edu
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-password

# Local development only: allow Express to stop/start fingerprint bridge processes.
ENABLE_FINGERPRINT_BRIDGE_CONTROL=false
